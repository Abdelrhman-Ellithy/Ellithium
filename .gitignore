# Test Output Management
Test-Output/*
!Test-Output/.gitkeep


# Preserve specific Test-Output structure
!Test-Output/Logs/
!Test-Output/Reports/
!Test-Output/ScreenShots/
!Test-Output/UpdateChecker/

# Keep specific files but ignore contents
Test-Output/UpdateChecker/*
!Test-Output/UpdateChecker/checker.json

# Allure Reports
Test-Output/Reports/Allure/*
!Test-Output/Reports/Allure/.gitkeep
src/test/java/ignore/*

# Cucumber Reports
Test-Output/Reports/Cucumber/*
!Test-Output/Reports/Cucumber/.gitkeep

# Screenshots from failed tests
Test-Output/ScreenShots/Failed/*
Test-Output/ScreenShots/Captured/*
Test-Output/RecordedExecutions/*
!Test-Output/ScreenShots/Failed/.gitkeep
!Test-Output/ScreenShots/Captured/.gitkeep
!Test-Output/RecordedExecutions/.gitkeep
# Logs directory
Test-Output/Logs/*
!Test-Output/Logs/.gitkeep

